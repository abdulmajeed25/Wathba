// Wathba domain schema (Prisma).
// All money in BigInt halalas (100 halalas = 1 SAR). Never floats.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, vector]
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  CREATOR
  BACKER
  SUPPLIER
  ADMIN
}

enum ReputationTier {
  NEWCOMER
  SUPPORTER
  ADVOCATE
  AMBASSADOR
  FOUNDER
}

enum ProjectCategory {
  TECH
  DESIGN
  FILM
  MUSIC
  FOOD
  GAMES
  PUBLISHING
  FASHION
  ART
  SOCIAL
}

enum ProjectStatus {
  DRAFT
  UNDER_REVIEW
  LIVE
  SUCCESSFUL
  FAILED
  FUNDED
  IN_PRODUCTION
  DELIVERED
  REFUNDED
}

enum PledgeStatus {
  HELD
  CAPTURED
  REFUNDED
  FAILED
}

enum ContractType {
  DONATION
  ISTISNA
  SALAM
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  APPROVED
  RELEASED
}

enum RFQStatus {
  OPEN
  AWARDED
  CLOSED
  CANCELLED
}

enum BidStatus {
  SUBMITTED
  SHORTLISTED
  AWARDED
  REJECTED
}

enum PayoutStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationKind {
  PLEDGE_RECEIVED
  PROJECT_FUNDED
  PROJECT_FAILED
  MILESTONE_APPROVED
  PAYOUT_SENT
  UPDATE_POSTED
  RANK_UP
}

// ============================================================================
// IDENTITY
// ============================================================================

model User {
  id                  String          @id @default(uuid()) @db.Uuid
  name                String
  email               String          @unique
  phone               String?
  passwordHash        String?
  roles               UserRole[]      @default([BACKER])
  nafathVerified      Boolean         @default(false)
  nafathVerifiedAt    DateTime?
  reputationTier      ReputationTier  @default(NEWCOMER)
  totalPledgedHalalas BigInt          @default(0)
  locale              String          @default("ar")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  projects            Project[]       @relation("ProjectCreator")
  pledges             Pledge[]
  comments            Comment[]
  notifications       Notification[]
  supplierBids        SupplierBid[]
  addresses           Address[]
  payouts             Payout[]        @relation("PayoutCreator")

  @@index([reputationTier])
  @@index([email])
}

model Address {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String?
  name      String
  address   String
  city      String
  country   String   @default("SA")
  postal    String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ============================================================================
// PROJECTS / REWARDS
// ============================================================================

model Project {
  id                   String          @id @default(uuid()) @db.Uuid
  titleAr              String
  shortDescAr          String
  category             ProjectCategory
  storyAr              String          @db.Text
  mediaUrls            String[]        @default([])
  fundingGoalHalalas   BigInt
  releaseThresholdPct  Int             @default(80)
  durationDays         Int
  deadline             DateTime
  status               ProjectStatus   @default(DRAFT)
  productSpecAr        String?         @db.Text
  expectedDeliveryDate DateTime?
  createdById          String          @db.Uuid
  createdBy            User            @relation("ProjectCreator", fields: [createdById], references: [id])
  raisedHalalas        BigInt          @default(0)
  backersCount         Int             @default(0)
  /// §7 — Wathba-as-co-founder marker. Null = normal community project.
  platformPartner      Json?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  publishedAt          DateTime?

  rewardTiers          RewardTier[]
  pledges              Pledge[]
  milestones           Milestone[]
  spendLogs            SpendLog[]
  rfqs                 RFQ[]
  updates              ProjectUpdate[]
  comments             Comment[]
  payouts              Payout[]

  // Hot-path query indexes:
  //  - (status, deadline)        → deadline scheduler tick
  //  - (status, publishedAt)     → "newest" sort on /projects/discover
  //  - (category, status)        → category filter + LIVE projects
  //  - (status, raisedHalalas)   → "most-funded" sort
  //  - (status, backersCount)    → "most-backers" sort
  //  - (platformPartner)         → §7 partner filter (gin/jsonb? for boolean lookups)
  @@index([status, deadline])
  @@index([status, publishedAt])
  @@index([category, status])
  @@index([status, raisedHalalas])
  @@index([status, backersCount])
  @@index([createdById])
}

model RewardTier {
  id                      String     @id @default(uuid()) @db.Uuid
  projectId               String     @db.Uuid
  project                 Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  titleAr                 String
  amountHalalas           BigInt
  descAr                  String     @db.Text
  includesPhysicalProduct Boolean    @default(false)
  requiresShipping        Boolean    @default(false)
  estDeliveryDate         DateTime
  limitQty                Int?
  claimedQty              Int        @default(0)
  popular                 Boolean    @default(false)
  sortOrder               Int        @default(0)
  createdAt               DateTime   @default(now())

  pledges                 Pledge[]

  // (projectId, sortOrder) → ordered tier list for the project page.
  @@index([projectId, sortOrder])
}

// ============================================================================
// FUNDING / PLEDGES
// ============================================================================

model Pledge {
  id            String       @id @default(uuid()) @db.Uuid
  backerId      String       @db.Uuid
  backer        User         @relation(fields: [backerId], references: [id])
  projectId     String       @db.Uuid
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tierId        String       @db.Uuid
  tier          RewardTier   @relation(fields: [tierId], references: [id])
  amountHalalas BigInt
  status        PledgeStatus @default(HELD)
  shipping      Json?
  contractType  ContractType @default(DONATION)
  paymentRef    String       @unique
  createdAt     DateTime     @default(now())
  capturedAt    DateTime?
  refundedAt    DateTime?

  // (projectId, status)      → funding aggregations
  // (backerId, createdAt)    → /v1/pledges/me chronological list
  // (backerId, status)       → "my held / captured / refunded" filters
  @@index([projectId, status])
  @@index([backerId, createdAt])
  @@index([backerId, status])
}

// ============================================================================
// MILESTONES + TRANSPARENCY
// ============================================================================

model Milestone {
  id               String          @id @default(uuid()) @db.Uuid
  projectId        String          @db.Uuid
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  order            Int
  titleAr          String
  releasePct       Int
  evidenceRequired String          @db.Text
  status           MilestoneStatus @default(PENDING)
  releasedHalalas  BigInt          @default(0)
  submittedAt      DateTime?
  approvedAt       DateTime?
  releasedAt       DateTime?
  evidenceUrl      String?

  spendLogs        SpendLog[]
  payouts          Payout[]

  @@unique([projectId, order])
  @@index([projectId])
}

model SpendLog {
  id            String     @id @default(uuid()) @db.Uuid
  projectId     String     @db.Uuid
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId   String?    @db.Uuid
  milestone     Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  amountHalalas BigInt
  descAr        String     @db.Text
  date          DateTime
  proofUrl      String?
  createdAt     DateTime   @default(now())

  @@index([projectId, date])
}

// ============================================================================
// PROCUREMENT
// ============================================================================

model RFQ {
  id           String        @id @default(uuid()) @db.Uuid
  projectId    String        @db.Uuid
  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  specsAr      String        @db.Text
  dueDate      DateTime
  status       RFQStatus     @default(OPEN)
  awardedBidId String?       @db.Uuid
  createdAt    DateTime      @default(now())
  bids         SupplierBid[]

  @@index([projectId])
  @@index([status, dueDate])
}

model SupplierBid {
  id                 String    @id @default(uuid()) @db.Uuid
  rfqId              String    @db.Uuid
  rfq                RFQ       @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplierId         String    @db.Uuid
  supplier           User      @relation(fields: [supplierId], references: [id])
  amountHalalas      BigInt
  leadTimeDays       Int
  specComplianceNote String    @db.Text
  status             BidStatus @default(SUBMITTED)
  createdAt          DateTime  @default(now())

  // (rfqId, status, amountHalalas) → sorted bid table for the RFQ owner
  // (supplierId, createdAt)        → "my bids" chronological list
  @@index([rfqId, status, amountHalalas])
  @@index([rfqId])
  @@index([supplierId, createdAt])
}

// ============================================================================
// PAYOUTS
// ============================================================================

model Payout {
  id             String       @id @default(uuid()) @db.Uuid
  projectId      String       @db.Uuid
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creatorId      String       @db.Uuid
  creator        User         @relation("PayoutCreator", fields: [creatorId], references: [id])
  amountHalalas  BigInt
  milestoneId    String       @db.Uuid
  milestone      Milestone    @relation(fields: [milestoneId], references: [id])
  status         PayoutStatus @default(PENDING)
  zatcaInvoiceId String?
  sentAt         DateTime?
  createdAt      DateTime     @default(now())

  // (creatorId, status, createdAt) → wallet view (SENT vs PENDING ordering)
  // (projectId, status)             → admin payouts queue
  @@index([projectId, status])
  @@index([creatorId, status, createdAt])
}

// ============================================================================
// UPDATES / COMMENTS / NOTIFICATIONS
// ============================================================================

model ProjectUpdate {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  titleAr   String
  bodyAr    String   @db.Text
  date      DateTime @default(now())

  @@index([projectId, date])
}

model Comment {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @db.Uuid
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id])
  bodyAr    String   @db.Text
  parentId  String?  @db.Uuid
  date      DateTime @default(now())

  // (projectId, parentId, date) → cursor pagination of top-level vs replies
  // (userId, date)              → user activity feed
  @@index([projectId, parentId, date])
  @@index([projectId, date])
  @@index([userId, date])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      NotificationKind
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())

  // (userId, readAt)    → unread-only filters
  // (userId, createdAt) → chronological inbox
  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ============================================================================
// DORMANT — INVESTMENT (§6).
// Never referenced by other contexts; no controllers; flagged OFF.
// ============================================================================

model InvestmentOffer {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @db.Uuid
  profitSharePct   Int
  minTicketHalalas BigInt
  termsAr          String   @db.Text
  status           String   @default("DORMANT")
  createdAt        DateTime @default(now())

  @@index([projectId])
}
