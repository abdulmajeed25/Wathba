# Wathba API — environment template
NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000

# PostgreSQL (pgvector + pgcrypto extensions)
DATABASE_URL=postgresql://wathba:wathba@localhost:5432/wathba?schema=public

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6379

# JWT — must be a strong random string ≥16 chars. Boot validation
# (IdentityModule + JwtStrategy) throws if missing, too short, or a
# placeholder like 'change-me'. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_BASE64URL_STRING_BEFORE_BOOTING
JWT_EXPIRES_IN=14d

# Nafath (KYC) — Phase 1 stub
NAFATH_BASE_URL=https://nafath.example.test
NAFATH_API_KEY=

# Moyasar Split (escrow)
MOYASAR_API_KEY=
MOYASAR_PUBLIC_KEY=
MOYASAR_WEBHOOK_SECRET=

# ZATCA Phase 2 (e-invoicing on platform commission only)
ZATCA_BASE_URL=
ZATCA_TENANT_ID=

# DORMANT — securities. Leave OFF.
INVESTMENT_ENABLED=false
