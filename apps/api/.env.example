# ──────────────────────────────────────────────────────────────────────────────
# Wathba API — environment template
# Copy to .env (gitignored). NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# CORS (comma separated) — Expo dev clients
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# PostgreSQL (with pgvector + pgcrypto extensions)
DATABASE_URL=postgresql://wathba:wathba@localhost:5432/wathba?schema=public

# Redis (BullMQ + cache)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me
JWT_EXPIRES_IN=14d

# Nafath (KYC) — stub in Phase 1
NAFATH_BASE_URL=https://nafath.example.test
NAFATH_API_KEY=

# Moyasar Split (escrow)
MOYASAR_API_KEY=
MOYASAR_PUBLIC_KEY=
MOYASAR_WEBHOOK_SECRET=

# ZATCA Phase 2 (e-invoicing on platform commission only)
ZATCA_BASE_URL=
ZATCA_TENANT_ID=

# Dormant — securities. Leave OFF.
INVESTMENT_ENABLED=false
